# ── Setu configuration ────────────────────────────────────────────────
# Dispatch mode: 'mock' (deterministic fixtures, no credits) or 'live'.
SETU_MODE=mock
SETU_SERVER_NAME=setu
SETU_LOG_LEVEL=INFO
SETU_RATE_LIMIT_PER_MINUTE=60

# ── Sarvam credentials (only needed once SETU_MODE=live, milestone 2+) ──
# Get a key + 100 free credits at https://dashboard.sarvam.ai
# SARVAM_API_KEY=your_key_here
# SARVAM_BASE_URL=https://api.sarvam.ai
# REQUEST_TIMEOUT_S=30
